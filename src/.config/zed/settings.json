						"reasoning_effort": "medium",
						"capabilities": {
							"tools": true,
							"images": false,
							"parallel_tool_calls": true,
							"prompt_cache_key": false,
							"chat_completions": true,
						},
					},
					{
						"name": "minimax-m2.5",
						"display_name": "Minimax M2.5",
						"max_tokens": 131072,
						"max_output_tokens": 32768,

// https://zed.dev/docs/configuring-zed
{
	"cli_default_open_behavior": "new_window",
	"on_last_window_closed": "quit_app",
	"when_closing_with_no_tabs": "keep_window_open",
	"show_edit_predictions": true,
	"edit_predictions": {
		"provider": "zed",
		"open_ai_compatible_api": {
			"prompt_format": "zeta2",
			"api_url": "http://127.0.0.1:7748/v1/completions",
			"model": "zeta-2",
		},
	},
	"agent": {
		"sidebar_side": "right",
		"dock": "right",
		"inline_assistant_model": {
			"provider": "wai",
			"model": "qwen-3.6-35b-a3b",
		},
		"favorite_models": [
			{
				"provider": "wai",
				"model": "minimax-m2.5",
				"enable_thinking": false,
			},
			{
				"provider": "wai",
				"model": "minimax-m2.7",
				"enable_thinking": false,
			},
			{
				"provider": "wai",
				"model": "gpt-oss-120b",
				"enable_thinking": false,
			},
			{
				"provider": "copilot_chat",
				"model": "claude-sonnet-4.6",
				"enable_thinking": true,
				"effort": "high",
			},
			{
				"provider": "wai",
				"model": "qwen-3.6-35b-a3b",
				"enable_thinking": false,
			},
		],
		"show_turn_stats": true,
		"play_sound_when_agent_done": "always",
		"default_profile": "write",
		"enabled": true,
		"default_model": {
			"enable_thinking": false,
			"provider": "wai",
			"model": "qwen-3.6-35b-a3b",
		},
	},
	"agent_servers": {
		"pi-acp": {
			"type": "registry",
		},
		"opencode": {
			"type": "extension",
			"favorite_models": [
				"wai/minimax-m2.5",
				"wai/minimax-m2.7",
				"wai/gemma-4-E4B-it",
				"wai/gemma-4-26B-A4B-it",
				"wai/qwen-3.6-35b-a3b",
			],
		},
	},
	"language_models": {

			"local": {
				"api_url": "http://127.0.0.1:7748/v1",
				"available_models": [
					{
						"name": "gemma-4-E4B-it",
						"display_name": "Gemma 4 E4B",
						"max_tokens": 131072,
						"max_output_tokens": 16384,
						"max_completion_tokens": 16384,

{
	"$schema": "https://opencode.ai/config.json",
	"plugin": ["@sveltejs/opencode@0.1.5", "@mohak34/opencode-notifier@0.2.1"],
	"mcp": {
		"tmcp-web": {
			"type": "remote",
			"url": "https://tmcp-web.willowdev.workers.dev/mcp",
			"enabled": false
		},
		"dotprompts": {
			"type": "remote",
			"url": "https://dotprompts.com/mcp",
			"enabled": false
		}
	},
	"model": "wai/minimax-m2.5",
	"small_model": "local/gemma-4-E4B-it",
	"provider": {
		"wai": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "wai",
			"options": {
				"baseURL": "https://ai.willow.sh/v1"
			},
			"models": {
				"gpt-oss-120b": {
					"name": "GPT OSS 120b",
					"cost": { "input": 0.07, "output": 0.28 },
					"reasoning": true,
					"tool_call": true,
					"limit": {
						"context": 131072,
						"input": 96304,
						"output": 32768
					}
				},
				"minimax-m2.5": {
					"name": "MiniMax M2.5",
					"cost": { "input": 0.3, "output": 1.2, "cache_read": 0.03 },
					"reasoning": true,
					"tool_call": true,
					"limit": {
						"context": 131072,
						"input": 96304,
						"output": 32768
					}
				},
				"minimax-m2.7": {
					"name": "MiniMax M2.7",
					"cost": { "input": 0.3, "output": 1.2, "cache_read": 0.06 },
					"reasoning": true,
					"tool_call": true,
					"interleaved": true,
					"limit": {
						"context": 65536,
						"input": 47152,
						"output": 16384
					}
				},
				"gemma-4-E2B-it": {
					"name": "Gemma 4 E2B",
					"cost": { "input": 0.13, "output": 0.4 },
					"reasoning": true,
					"tool_call": true,
					"attachment": true,
					"modalities": {
						"input": ["text", "image", "audio"],
						"output": ["text"]
					},
					"limit": {
						"context": 131072,
						"input": 112688,
						"output": 16384
					}
				}
			}
		},
		"local": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "local",
			"options": {
				"baseURL": "http://127.0.0.1:7748/v1"
			},
			"models": {
				"gemma-4-E4B-it": {
					"name": "Gemma 4 E4B",
					"modalities": {
						"input": ["text", "image", "audio"],
						"output": ["text"]
					},
					"limit": {
						"context": 131072,
						"output": 16384,
						"input": 112688
					}
				}
			}
		}
	}
}

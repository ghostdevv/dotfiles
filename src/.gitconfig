[user]
	name = Willow (GHOST)
	email = git@willow.sh

[init]
	defaultBranch = main

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta "ghost"]
    syntax-theme = serendipity-sunset-v1

[delta]
    features = ghost
    dark = true
    side-by-side = true

[merge]
    conflictStyle = zdiff3

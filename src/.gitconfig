[user]
	name = Willow (GHOST)
	email = git@willow.sh

[user]
    signingkey = __GIT_SIGNING_KEY__

[gpg]
    format = ssh

[gpg "ssh"]
    program = "/opt/1Password/op-ssh-sign"
    allowedSignersFile = "__HOME__/.ssh/allowed_signers"

[commit]
    gpgsign = true

[init]
	defaultBranch = main

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta "ghost"]
    syntax-theme = serendipity-sunset-v1

[delta]
    features = ghost
    dark = true
    side-by-side = true

[merge]
    conflictStyle = zdiff3
